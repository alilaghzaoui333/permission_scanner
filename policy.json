{
  "file_perm": "644",
  "dir_perm": "755",
  "remove_world_write": true,
  "remove_setuid": true,
  "remove_setgid": true,
  "log_changes": true,
  "exceptions": [
    "/tmp",
    "/var/tmp",
    "/proc",
    "/sys",
    "/dev",
    "./.git",
    "./logs",
    "./reports",
    "./scanner.sh",
    "./policy.json"
  ]
}